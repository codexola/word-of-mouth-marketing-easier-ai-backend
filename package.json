{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "vercel-build": "npx prisma generate && npm run build",
    "postinstall": "npx prisma generate",
    "start": "node dist/index.js",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:push:quick": "npx prisma db push --skip-generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "node scripts/setup-database.mjs && prisma db push && tsx prisma/seed.ts",
    "db:test": "node scripts/test-connection.mjs",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "googleapis": "^148.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.11",
    "openai": "4.104.0",
    "pg": "^8.16.0",
    "prisma": "^6.8.2",
    "typescript": "^5.8.3",
    "zod": "^3.25.28"
  },
  "overrides": {
    "uuid": "^11.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "tsx": "^4.19.4"
  }
}
