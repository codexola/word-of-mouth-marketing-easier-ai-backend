# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Vercel / custom domain (comma-separated for multiple)
# FRONTEND_URL=https://your-app.vercel.app
# ALLOWED_ORIGINS=https://your-app.vercel.app
# ALLOW_VERCEL_ORIGINS=true

# Database
# Local: postgresql://postgres:password@localhost:5432/gbp_content_manager?schema=public
# Neon (pooled — use for app runtime):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Neon (direct — use for migrations / prisma db push):
# DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Developer login (backend .env only — not stored in database)
DEVELOPER_EMAIL=your-developer@example.com
DEVELOPER_PASSWORD=your-developer-password

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Google Drive
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# LINE Messaging API (also configurable in Settings UI)
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
PUBLIC_API_URL=http://localhost:4000

# Google Business Profile OAuth (auto-post on approve)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/gbp/callback

# Gmail API OAuth (review-request emails — falls back to GOOGLE_OAUTH_* if unset)
GMAIL_OAUTH_CLIENT_ID=your-google-oauth-client-id
GMAIL_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_OAUTH_REDIRECT_URI=http://localhost:4000/api/gmail/callback

# SMTP (also configurable in Settings UI — for automatic review-request emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Your Business <noreply@example.com>"
